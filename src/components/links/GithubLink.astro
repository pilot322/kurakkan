---
import { SOCIAL_LINKS } from '@/consts';
import GithubLight from '@/assets/logos/github_light.svg';
import GithubDark from '@/assets/logos/github_dark.svg';
import LogoLink from '@/components/links/LogoLink.astro';

interface Props {
	class?: string;
}
const { class: className = '' } = Astro.props;
---

<LogoLink href={SOCIAL_LINKS.github} label="GitHub" external class={className}>
	<span class="relative inline-block w-8 h-8 [&>svg]:absolute [&>svg]:inset-0 [&>svg]:w-full [&>svg]:h-full [&>svg]:transition-opacity [&>svg]:duration-300">
		<GithubLight class="dark:opacity-0" />
		<GithubDark class="opacity-0 dark:opacity-100" />
	</span>
</LogoLink>
