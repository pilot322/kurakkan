<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 250" width="100%" height="100%">
  <!-- Set overall styling to match the hand-drawn look -->
  <g stroke="currentColor" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" fill="none">
    
    <!-- Left parallel line -->
    <line x1="72" y1="205" x2="105" y2="60" />
    
    <!-- Right parallel line -->
    <line x1="82" y1="200" x2="118" y2="55" />
    
    <!-- Top horizontal curved line -->
    <path d="M 62,82 C 75,70 82,120 100,120 C 115,120 135,122 148,120" />
    
    <!-- Bottom sweeping curved line -->
    <path d="M 52,148 C 72,120 88,135 98,145 C 112,165 125,185 140,180 C 155,175 160,150 165,140" />
    
  </g>
  
  <!-- Small dot at the top -->
  <circle cx="95" cy="58" r="2.5" fill="currentColor" />
</svg>
